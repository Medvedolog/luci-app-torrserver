#!/bin/sh
# rpcd exec plugin for LuCI TorrServer backend.
# Object: torrserver
# Path on target: /usr/libexec/rpcd/torrserver
# No rpcd-mod-ucode, no ucode-mod-fs, no rpcd-mod-file.

BIN_PATH="/usr/bin/torrserver"
INIT_PATH="/etc/init.d/torrserver"
CFG_PATH="/etc/config/torrserver"
STATE_FILE="/tmp/ts_monitor_state"

_trim() { sed 's/^[[:space:]]*//;s/[[:space:]]*$//' 2>/dev/null; }

json_string() {
	awk 'BEGIN { printf "\"" }
	{
		gsub(/\\/, "\\\\");
		gsub(/\"/, "\\\"");
		gsub(/\r/, "\\r");
		gsub(/\t/, "\\t");
		if (NR > 1) printf "\\n";
		printf "%s", $0;
	}
	END { printf "\"" }'
}

is_running() {
	[ -x "$INIT_PATH" ] && "$INIT_PATH" running >/dev/null 2>&1 && return 0
	return 1
}

get_pid() {
	for c in /proc/[0-9]*/cmdline; do
		[ -r "$c" ] || continue
		cl=$(tr '\0' ' ' < "$c" 2>/dev/null) || continue
		case "$cl" in
			*"/etc/init.d/torrserver"*) continue ;;
			*"rc.common"*) continue ;;
			"$BIN_PATH"|"$BIN_PATH "*)
				p=${c#/proc/}; p=${p%/cmdline}; printf '%s\n' "$p"; return 0 ;;
		esac
	done
	pgrep -f "^${BIN_PATH}([[:space:]]|$)" 2>/dev/null | head -n 1
}

proc_exists() { [ -n "$1" ] && [ -d "/proc/$1" ]; }

kill_lingering() {
	pids=$(pgrep -f "^${BIN_PATH}([[:space:]]|$)" 2>/dev/null | tr '\n' ' ')
	[ -n "$pids" ] || return 0
	kill -TERM $pids 2>/dev/null || true
	i=0
	while [ "$i" -lt 10 ]; do
		pgrep -f "^${BIN_PATH}([[:space:]]|$)" >/dev/null 2>&1 || return 0
		sleep 0.3 2>/dev/null || true
		i=$((i + 1))
	done
	pids=$(pgrep -f "^${BIN_PATH}([[:space:]]|$)" 2>/dev/null | tr '\n' ' ')
	[ -n "$pids" ] && kill -KILL $pids 2>/dev/null || true
	sleep 0.3 2>/dev/null || true
	pgrep -f "^${BIN_PATH}([[:space:]]|$)" >/dev/null 2>&1 && return 1
	return 0
}

wait_state() {
	want="$1"
	max_ms="${2:-3000}"
	steps=$((max_ms / 300))
	[ "$steps" -lt 1 ] && steps=1
	i=0
	while [ "$i" -lt "$steps" ]; do
		if is_running; then cur=1; else cur=0; fi
		[ "$cur" = "$want" ] && return 0
		sleep 0.3 2>/dev/null || true
		i=$((i + 1))
	done
	if is_running; then cur=1; else cur=0; fi
	[ "$cur" = "$want" ]
}

cpu_count() { grep -c '^cpu[0-9]' /proc/stat 2>/dev/null || echo 0; }

emit_cores() {
	first=1
	awk '/^cpu[0-9]+[[:space:]]/ { print $1, $2 + $3 + $4 + $5, $2 + $3 + $4 }' /proc/stat 2>/dev/null |
	while read -r name total work; do
		pct="0.0"
		if [ -r "$STATE_FILE" ]; then
			prev=$(grep "^${name} " "$STATE_FILE" 2>/dev/null)
			pt=$(printf '%s\n' "$prev" | awk '{print $2}')
			pw=$(printf '%s\n' "$prev" | awk '{print $3}')
			if [ -n "$pt" ] && [ -n "$pw" ]; then
				dt=$((total - pt))
				dw=$((work - pw))
				if [ "$dt" -gt 0 ] 2>/dev/null; then
					pct=$(awk -v dw="$dw" -v dt="$dt" 'BEGIN { printf "%.1f", (dw / dt) * 100 }')
				fi
			fi
		fi
		[ "$first" = 1 ] || printf ','
		printf '%s' "$pct"
		first=0
	done
}

write_state() {
	pid="$1"
	proc_ticks="$2"
	{
		awk '/^cpu[0-9]*[[:space:]]/ { print $1, $2 + $3 + $4 + $5, $2 + $3 + $4 }' /proc/stat 2>/dev/null
		printf 'pid %s %s\n' "${pid:-0}" "${proc_ticks:-0}"
	} > "$STATE_FILE.$$" 2>/dev/null && mv "$STATE_FILE.$$" "$STATE_FILE" 2>/dev/null || rm -f "$STATE_FILE.$$" 2>/dev/null
}

method_status() {
	has_bin=false;  [ -x "$BIN_PATH" ]  && has_bin=true
	has_init=false; [ -x "$INIT_PATH" ] && has_init=true
	has_cfg=false;  [ -f "$CFG_PATH" ]  && has_cfg=true

	if is_running; then running=true; else running=false; fi
	pid=""
	[ "$running" = true ] && pid=$(get_pid)
	proc_ticks=0
	mem_kb=0
	if proc_exists "$pid"; then
		mem_kb=$(awk '/^VmRSS:/ { print $2; exit }' "/proc/$pid/status" 2>/dev/null)
		[ -n "$mem_kb" ] || mem_kb=0
		proc_ticks=$(awk '{ print $14 + $15 }' "/proc/$pid/stat" 2>/dev/null)
		[ -n "$proc_ticks" ] || proc_ticks=0
	else
		pid=""
	fi

	mem_total=$(awk '/^MemTotal:/ { print $2; exit }' /proc/meminfo 2>/dev/null); [ -n "$mem_total" ] || mem_total=0
	mem_free=$(awk '/^MemFree:/ { print $2; exit }' /proc/meminfo 2>/dev/null); [ -n "$mem_free" ] || mem_free=0
	mem_avail=$(awk '/^MemAvailable:/ { print $2; exit }' /proc/meminfo 2>/dev/null); [ -n "$mem_avail" ] || mem_avail="$mem_free"

	ts_cpu="0.0"
	if [ -n "$pid" ] && [ -r "$STATE_FILE" ]; then
		cur_cpu=$(awk '/^cpu / { print $2 + $3 + $4 + $5; exit }' /proc/stat 2>/dev/null)
		prev_cpu=$(awk '/^cpu / { print $2; exit }' "$STATE_FILE" 2>/dev/null)
		prev_pid=$(awk '/^pid / { print $2; exit }' "$STATE_FILE" 2>/dev/null)
		prev_proc=$(awk '/^pid / { print $3; exit }' "$STATE_FILE" 2>/dev/null)
		if [ "$prev_pid" = "$pid" ] && [ -n "$cur_cpu" ] && [ -n "$prev_cpu" ] && [ -n "$prev_proc" ]; then
			d_sys=$((cur_cpu - prev_cpu))
			d_proc=$((proc_ticks - prev_proc))
			ncpu=$(cpu_count); [ -n "$ncpu" ] && [ "$ncpu" -gt 0 ] 2>/dev/null || ncpu=1
			if [ "$d_sys" -gt 0 ] 2>/dev/null; then
				ts_cpu=$(awk -v dp="$d_proc" -v ds="$d_sys" -v n="$ncpu" 'BEGIN { printf "%.1f", (dp / ds) * 100 * n }')
			fi
		fi
	fi

	cores=$(emit_cores)
	write_state "$pid" "$proc_ticks"

	if [ -n "$pid" ]; then pid_json="$pid"; else pid_json=null; fi
	printf '{"running":%s,"pid":%s,"bin_present":%s,"init_present":%s,"config_present":%s,"mem_kb":%s,"ts_cpu":"%s","sys_mem":{"total":%s,"free":%s,"available":%s},"cores":[%s]}\n' \
		"$running" "$pid_json" "$has_bin" "$has_init" "$has_cfg" "${mem_kb:-0}" "$ts_cpu" \
		"$mem_total" "$mem_free" "$mem_avail" "$cores"
}

method_log() {
	if command -v logread >/dev/null 2>&1; then
		out=$(logread -e torrserver 2>/dev/null | tail -n 200)
	else
		out=""
	fi
	[ -n "$out" ] || out="Нет событий torrserver в логе."
	printf '{"log":%s}\n' "$(printf '%s' "$out" | json_string)"
}

method_start() {
	[ -x "$INIT_PATH" ] || { printf '{"ok":false,"pid":null,"detail":"init_missing"}\n'; return; }
	"$INIT_PATH" start >/dev/null 2>&1
	init_rc=$?
	if [ "$init_rc" -eq 0 ] && wait_state 1 3000; then
		pid=$(get_pid)
		[ -n "$pid" ] || pid=null
		printf '{"ok":true,"pid":%s,"detail":"started"}\n' "$pid"
	else
		printf '{"ok":false,"pid":null,"detail":"%s","init_rc":%s}\n' "$([ "$init_rc" -eq 0 ] && printf start_no_process || printf init_failed)" "$init_rc"
	fi
}

method_stop() {
	[ -x "$INIT_PATH" ] || { printf '{"ok":false,"detail":"init_missing","init_rc":127}\n'; return; }
	"$INIT_PATH" stop >/dev/null 2>&1
	init_rc=$?
	if wait_state 0 3000; then
		printf '{"ok":true,"detail":"stopped_clean","init_rc":%s}\n' "$init_rc"
	elif kill_lingering; then
		printf '{"ok":true,"detail":"stopped_killed","init_rc":%s}\n' "$init_rc"
	else
		printf '{"ok":false,"detail":"lingering_processes","init_rc":%s}\n' "$init_rc"
	fi
}

method_restart() {
	[ -x "$INIT_PATH" ] || { printf '{"ok":false,"pid":null,"detail":"init_missing"}\n'; return; }
	"$INIT_PATH" stop >/dev/null 2>&1 || true
	wait_state 0 3000 || kill_lingering || true
	sleep 0.5 2>/dev/null || true
	"$INIT_PATH" start >/dev/null 2>&1
	init_rc=$?
	if [ "$init_rc" -eq 0 ] && wait_state 1 3000; then
		pid=$(get_pid)
		[ -n "$pid" ] || pid=null
		printf '{"ok":true,"pid":%s,"detail":"restarted"}\n' "$pid"
	else
		printf '{"ok":false,"pid":null,"detail":"%s","init_rc":%s}\n' "$([ "$init_rc" -eq 0 ] && printf start_no_process || printf start_failed)" "$init_rc"
	fi
}

method_enable() {
	[ -x "$INIT_PATH" ] || { printf '{"ok":false,"detail":"init_missing"}\n'; return; }
	"$INIT_PATH" enable >/dev/null 2>&1
	rc=$?
	printf '{"ok":%s,"init_rc":%s}\n' "$([ "$rc" -eq 0 ] && printf true || printf false)" "$rc"
}

method_disable() {
	[ -x "$INIT_PATH" ] || { printf '{"ok":false,"detail":"init_missing"}\n'; return; }
	"$INIT_PATH" disable >/dev/null 2>&1
	rc=$?
	printf '{"ok":%s,"init_rc":%s}\n' "$([ "$rc" -eq 0 ] && printf true || printf false)" "$rc"
}

case "$1" in
	list)
		printf '{"status":{},"log":{},"start":{},"stop":{},"restart":{},"enable":{},"disable":{}}\n'
		;;
	call)
		case "$2" in
			status) method_status ;;
			log) method_log ;;
			start) method_start ;;
			stop) method_stop ;;
			restart) method_restart ;;
			enable) method_enable ;;
			disable) method_disable ;;
			*) printf '{"error":"unknown method"}\n'; exit 1 ;;
		esac
		;;
	*)
		printf '{"error":"unknown command"}\n'
		exit 1
		;;
esac
