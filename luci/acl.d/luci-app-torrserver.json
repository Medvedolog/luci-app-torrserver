{
  "luci-app-torrserver": {
    "description": "Grant access to TorrServer status, diagnostics and service control",
    "read": {
      "ubus": {
        "luci.torrserver": [
          "status",
          "log"
        ],
        "uci": [
          "get",
          "changes"
        ]
      },
      "uci": [
        "torrserver"
      ]
    },
    "write": {
      "ubus": {
        "luci": [
          "setInitAction"
        ]
      },
      "uci": [
        "torrserver"
      ]
    }
  }
}
