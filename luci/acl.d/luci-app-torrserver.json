{
  "luci-app-torrserver": {
    "description": "Grant access to TorrServer UCI, service control and optional RPC backend",
    "read": {
      "ubus": {
        "luci": [ "getInitList", "getProcessList" ],
        "torrserver": [ "status", "log" ],
        "network.interface.lan": [ "status" ],
        "uci": [ "get", "changes" ]
      },
      "uci": [ "torrserver", "network" ]
    },
    "write": {
      "ubus": {
        "luci": [ "setInitAction" ],
        "torrserver": [ "start", "stop", "restart", "enable", "disable" ]
      },
      "uci": [ "torrserver" ]
    }
  }
}
