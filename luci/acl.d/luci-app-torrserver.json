{
  "luci-app-torrserver": {
    "description": "Grant access for TorrServer LuCI app",
    "read": {
      "ubus": {
        "service": [ "list" ],
        "file":    [ "read", "exec" ],
        "luci":    [ "setInitAction" ]
      },
      "uci": [ "torrserver", "network" ]
    },
    "write": {
      "ubus": {
        "file": [ "exec" ],
        "luci": [ "setInitAction" ]
      },
      "uci": [ "torrserver" ]
    }
  }
}
